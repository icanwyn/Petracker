{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "student.html", "use": "@vercel/static" },
    { "src": "api/send-email.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/send-email", "dest": "/api/send-email.js" },
    { "src": "/student", "dest": "/student.html" },
    { "src": "/student.html", "dest": "/student.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
